{
  "extends": "./tsconfig.base.json",

  "compilerOptions": {
    "composite": true,

    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],

    "module": "ESNext",

    "types": ["vite/client"],

