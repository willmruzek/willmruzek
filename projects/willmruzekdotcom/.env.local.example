# Set to 'true' to enable blog features (navigation, routes, RSS)
ENABLE_BLOG=false

# Set to 'true' to show red baseline grid lines for typography debugging
SHOW_BASELINE_GRID=false

# Site URL for metadata (used for Open Graph and Twitter images)
# In production, set this to your actual domain (e.g., https://willmruzek.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
