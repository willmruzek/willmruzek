{
  "search.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "package-lock.json": true
  },
  "files.watcherExclude": {
    "**/.next/**": true,
    "**/node_modules/**": true
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "nixEnvSelector.nixFile": "${workspaceFolder}/devenv.nix"
}
