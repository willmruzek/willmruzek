{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "featured": {
      "type": "boolean"
    },
    "image": {
      "type": "string",
      "minLength": 1,
      "description": "Path to custom Open Graph image. If provided, automatic OG image generation will be skipped."
    }
  },
  "required": ["title"]
}
